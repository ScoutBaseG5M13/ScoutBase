<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="scoutbase.dashboard.DashboardController"
            prefWidth="900.0"
            prefHeight="600.0"
            styleClass="root-container">

    <top>
        <VBox spacing="10.0" styleClass="top-bar">
            <padding>
                <Insets top="10.0" right="12.0" bottom="10.0" left="12.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label fx:id="appTitleLabel"
                       text="Scoutbase"
                       onMouseClicked="#onInicioClick"
                       styleClass="app-title"
                       style="-fx-cursor: hand;" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="userInfoLabel"
                       styleClass="user-info-label" />

                <Button fx:id="themeToggleButton"
                        text="Modo claro"
                        onAction="#onToggleThemeClick"
                        styleClass="menu-button" />

                <Button text="Cerrar sesión"
                        onAction="#onLogoutClick"
                        styleClass="logout-button" />
            </HBox>

            <HBox spacing="10.0">
                <Button fx:id="jugadoresButton"
                        text="Jugadores"
                        onAction="#onJugadoresClick"
                        prefWidth="120.0"
                        prefHeight="34.0"
                        styleClass="menu-button" />

                <Button fx:id="clubesButton"
                        text="Clubes"
                        onAction="#onClubesClick"
                        prefWidth="120.0"
                        prefHeight="34.0"
                        styleClass="menu-button" />

                <Button fx:id="informesButton"
                        text="Informes"
                        onAction="#onInformesClick"
                        prefWidth="120.0"
                        prefHeight="34.0"
                        styleClass="menu-button" />

                <Button fx:id="estadisticasButton"
                        text="Estadísticas"
                        onAction="#onEstadisticasClick"
                        prefWidth="120.0"
                        prefHeight="34.0"
                        styleClass="menu-button" />

                <Button fx:id="scoutsButton"
                        text="Scouts"
                        onAction="#onScoutsClick"
                        prefWidth="120.0"
                        prefHeight="34.0"
                        styleClass="menu-button" />

                <Button fx:id="usuariosButton"
                        text="Usuarios"
                        onAction="#onUsuariosClick"
                        prefWidth="120.0"
                        prefHeight="34.0"
                        styleClass="menu-button" />
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane styleClass="center-panel">
            <VBox fx:id="contentContainer"
                  spacing="12.0"
                  fillWidth="true"
                  style="-fx-padding: 30;" />
        </StackPane>
    </center>

</BorderPane>