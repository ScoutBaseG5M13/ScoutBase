<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="scoutbase.DashboardController"
            prefWidth="900.0"
            prefHeight="600.0"
            stylesheets="@dark_theme.css"
            styleClass="root-container">

    <top>
        <VBox spacing="10.0" styleClass="top-bar">
            <padding>
                <Insets top="10.0" right="12.0" bottom="10.0" left="12.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Scoutbase"
                       styleClass="app-title" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="userInfoLabel"
                       styleClass="user-info-label" />

                <Button text="Cerrar sesión"
                        onAction="#onLogoutClick"
                        styleClass="logout-button" />
            </HBox>

            <HBox spacing="10.0">
                <Button text="Jugadores"
                        onAction="#onJugadoresClick"
                        prefWidth="120.0"
                        prefHeight="34.0"
                        styleClass="menu-button" />

                <Button text="Clubes"
                        onAction="#onClubesClick"
                        prefWidth="120.0"
                        prefHeight="34.0"
                        styleClass="menu-button" />

                <Button text="Informes"
                        onAction="#onInformesClick"
                        prefWidth="120.0"
                        prefHeight="34.0"
                        styleClass="menu-button" />

                <Button text="Estadísticas"
                        onAction="#onEstadisticasClick"
                        prefWidth="120.0"
                        prefHeight="34.0"
                        styleClass="menu-button" />

                <Button text="Scouts"
                        onAction="#onScoutsClick"
                        prefWidth="120.0"
                        prefHeight="34.0"
                        styleClass="menu-button" />

                <Button text="Usuarios"
                        onAction="#onUsuariosClick"
                        prefWidth="120.0"
                        prefHeight="34.0"
                        styleClass="menu-button" />
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane styleClass="center-panel">
            <VBox alignment="CENTER" spacing="12.0">
                <Label text="Menú principal provisional"
                       styleClass="dashboard-title" />

                <Label fx:id="welcomeLabel"
                       styleClass="welcome-label" />
            </VBox>
        </StackPane>
    </center>

</BorderPane>