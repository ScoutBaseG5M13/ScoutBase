<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="scoutbase.DashboardController"
            prefWidth="900.0"
            prefHeight="600.0"
            style="-fx-background-color: #F2F5F7;">

    <top>
        <VBox spacing="8.0">
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>

            <!-- 👤 Usuario y rol -->
            <HBox alignment="CENTER_RIGHT">
                <Label fx:id="userInfoLabel"
                       style="-fx-font-size: 14px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #333333;" />
            </HBox>

            <!-- 🔒 Botón logout -->
            <HBox alignment="CENTER_RIGHT">
                <Button text="Cerrar sesión"
                        onAction="#onLogoutClick"
                        style="-fx-background-color: #D9534F;
                           -fx-text-fill: white;
                           -fx-background-radius: 8;" />
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane>
            <VBox alignment="CENTER" spacing="12.0">
                <Label text="Dashboard Scoutbase"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0A3D62;" />

                <Label fx:id="welcomeLabel"
                       style="-fx-font-size: 16px;" />
            </VBox>
        </StackPane>
    </center>

</BorderPane>