<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="scoutbase.PlayersController">
    <children>
        <VBox spacing="15.0"
              AnchorPane.topAnchor="20.0"
              AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0"
              AnchorPane.bottomAnchor="20.0">

            <Label text="Gestión de jugadores" styleClass="dashboard-title" />

            <Label text="Listado de jugadores del equipo seleccionado"
                   styleClass="section-subtitle" />

            <HBox spacing="10.0">
                <Button text="Recargar"
                        onAction="#onReloadClick"
                        styleClass="quick-action-button" />
            </HBox>

            <TableView fx:id="playersTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="220.0" />
                    <TableColumn fx:id="nameColumn" text="Nombre" prefWidth="160.0" />
                    <TableColumn fx:id="surnameColumn" text="Apellido" prefWidth="160.0" />
                    <TableColumn fx:id="ageColumn" text="Edad" prefWidth="90.0" />
                    <TableColumn fx:id="positionColumn" text="Posición" prefWidth="150.0" />
                </columns>
            </TableView>
            <Button text="Añadir jugador"
                    onAction="#onAddPlayerClick"
                    styleClass="quick-action-button" />
            <Label fx:id="statusLabel" styleClass="panel-text" />
        </VBox>
    </children>
</AnchorPane>